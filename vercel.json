{
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "sunfurns.com" }], "destination": "https://www.sunfurns.com/$1", "permanent": true }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }] }
  ]
}